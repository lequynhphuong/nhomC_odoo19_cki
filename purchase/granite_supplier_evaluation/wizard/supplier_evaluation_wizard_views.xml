<odoo>
    <record id="view_supplier_evaluation_wizard_form" model="ir.ui.view">
        <field name="name">supplier.evaluation.wizard.form</field>
        <field name="model">supplier.evaluation.wizard</field>
        <field name="arch" type="xml">
            <form string="Đánh Giá Nhà Cung Cấp">
                <sheet>
                    <!-- Header info -->
                    <group string="Thông Tin Phiếu Nhập">
                        <group>
                            <field name="partner_id" readonly="1"/>
                            <field name="purchase_order_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="stock_picking_id" readonly="1"/>
                            <field name="scheduled_date" readonly="1"/>
                            <field name="date_done" readonly="1"/>
                        </group>
                    </group>

                    <!-- Delivery score preview -->
                    <group string="Điểm Giao Hàng (Tự Động)">
                        <group>
                            <field name="delivery_delay_days" readonly="1"/>
                        </group>
                        <group>
                            <field name="score_delivery_preview" readonly="1"
                                   string="Điểm Giao Hàng"/>
                        </group>
                    </group>

                    <!-- Quality input -->
                    <group string="Điểm Chất Lượng &amp; Số Lượng ★ (Bắt Buộc)">
                        <field name="score_quality" widget="radio"
                               nolabel="1"/>
                    </group>

                    <!-- Tags -->
                    <group string="Nhãn Nhà Cung Cấp">
                        <field name="tag_ids" widget="many2many_tags"
                               options="{'color_field': 'color'}"
                               nolabel="1"/>
                    </group>

                    <!-- Note -->
                    <group string="Ghi Chú">
                        <field name="note" nolabel="1"
                               placeholder="Ghi chú về lô hàng, chất lượng, vấn đề phát sinh..."/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_save_evaluation" type="object"
                            string="💾 Lưu Đánh Giá" class="btn-primary"/>
                    <button string="✕ Bỏ Qua" class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_supplier_evaluation_wizard" model="ir.actions.act_window">
        <field name="name">Đánh Giá Nhà Cung Cấp</field>
        <field name="res_model">supplier.evaluation.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>