<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Kế thừa Sale Order form: thêm smart button và nút tạo phiếu -->
    <record id="view_sale_order_simple_production_inherit" model="ir.ui.view">
        <field name="name">sale.order.simple.production.inherit</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <!-- Smart button: hiện số phiếu sản xuất -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_productions" type="object"
                    class="oe_stat_button" icon="fa-industry"
                    invisible="state == 'draft'">
                    <field name="production_count" widget="statinfo" string="Phiếu SX"/>
                </button>
            </xpath>

            <!-- Nút tạo phiếu sản xuất trong header -->
            <xpath expr="//header/button[last()]" position="after">
                <button name="action_create_production" type="object"
                    string="Tạo Phiếu Sản Xuất"
                    class="btn-secondary"
                    invisible="state != 'sale'"/>
            </xpath>

        </field>
    </record>

</odoo>
