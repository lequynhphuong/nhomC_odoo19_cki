<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_form_inherit_granite_area" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.granite.area</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='order_line']/list/field[@name='product_template_id']"
                   position="after">
                <field name="length" string="Length" optional="show"/>
                <field name="width" string="Width" optional="show"/>
                <field name="area" string="Area m²" readonly="1" optional="show"/>
            </xpath>
        </field>
    </record>
</odoo>