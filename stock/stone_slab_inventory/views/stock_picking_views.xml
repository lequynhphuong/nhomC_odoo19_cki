<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_stock_picking_slab_form_inherit" model="ir.ui.view">
        <field name="name">stock.picking.slab.form.inherit</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">

            <!-- Nút Sync Slab Quantity trong header, chỉ hiện cho phiếu nhập -->
            <xpath expr="//header/field[@name='state']" position="before">
                <button name="action_sync_slab_quantity"
                        string="Sync Slab Quantity"
                        type="object"
                        class="btn-secondary"
                        invisible="picking_type_code != 'incoming'"
                        groups="stock.group_stock_user"/>
            </xpath>

            <!-- Tab Chi Tiết Tấm Đá, thêm vào notebook, chỉ hiện cho phiếu nhập -->
            <xpath expr="//notebook" position="inside">
                <page string="Chi Tiết Tấm Đá" name="slab_details"
                      invisible="picking_type_code != 'incoming'">
                    <field name="slab_line_ids"
                           context="{
                               'default_picking_id': id,
                           }">
                        <list editable="bottom"
                              decoration-warning="quality_status == 'pending'"
                              decoration-danger="quality_status == 'defective'">
                            <field name="lot_id"
                                   domain="[('product_id.product_tmpl_id.is_slab_product', '=', True)]"
                                   context="{'default_picking_id': parent.id}"/>
                            <field name="product_id" readonly="1" optional="show"/>
                            <field name="sku_code" readonly="1" optional="show" string="SKU"/>
                            <field name="length_cm" string="Dài (cm)"/>
                            <field name="width_cm" string="Rộng (cm)"/>
                            <field name="slab_count" string="Số Tấm"/>
                            <field name="area_m2" string="Diện Tích (m²)" readonly="1"/>
                            <field name="quality_status" widget="badge"
                                decoration-success="quality_status == 'normal'"
                                decoration-warning="quality_status == 'pending'"
                                decoration-danger="quality_status == 'defective'"/>
                            <field name="location_id" string="Vị Trí" optional="hide"/>
                            <field name="note" string="Ghi Chú" optional="hide"/>
                        </list>
                    </field>
                    <div class="alert alert-warning" role="alert"
                         invisible="picking_type_code != 'incoming'">
                        Sau khi nhập đủ tấm đá và đánh giá chất lượng, hãy bấm
                        <strong>Sync Slab Quantity</strong> để đồng bộ số lượng m²
                        vào phiếu nhập trước khi xác nhận.
                        Chỉ những tấm <strong>Đạt</strong> mới được tính vào tồn kho.
                    </div>
                </page>
            </xpath>

        </field>
    </record>

</odoo>
