<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- List View -->
    <record id="view_stone_slab_line_list" model="ir.ui.view">
        <field name="name">stone.slab.line.list</field>
        <field name="model">stone.slab.line</field>
        <field name="arch" type="xml">
            <list string="Danh Sách Tấm Đá"
                  decoration-warning="quality_status == 'pending'"
                  decoration-danger="quality_status == 'defective'">
                <field name="lot_id"/>
                <field name="product_id"/>
                <field name="sku_code"/>
                <field name="length_cm" string="Dài (cm)"/>
                <field name="width_cm" string="Rộng (cm)"/>
                <field name="slab_count" string="Số Tấm"/>
                <field name="area_m2" string="Diện Tích (m²)"/>
                <field name="quality_status" widget="badge"
                    decoration-success="quality_status == 'normal'"
                    decoration-warning="quality_status == 'pending'"
                    decoration-danger="quality_status == 'defective'"/>
                <field name="location_id"/>
                <field name="picking_id"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_stone_slab_line_form" model="ir.ui.view">
        <field name="name">stone.slab.line.form</field>
        <field name="model">stone.slab.line</field>
        <field name="arch" type="xml">
            <form string="Tấm Đá">
                <sheet>
                    <group>
                        <group string="Thông Tin Lô">
                            <field name="lot_id"/>
                            <field name="product_id" readonly="1"/>
                            <field name="sku_code" readonly="1"/>
                            <field name="picking_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group string="Kích Thước">
                            <field name="length_cm"/>
                            <field name="width_cm"/>
                            <field name="slab_count"/>
                            <field name="area_m2" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <group string="Chất Lượng &amp; Vị Trí">
                            <field name="quality_status" widget="radio"/>
                            <field name="location_id"/>
                        </group>
                    </group>
                    <group>
                        <field name="note" placeholder="Ghi chú về tấm đá này..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_stone_slab_line_search" model="ir.ui.view">
        <field name="name">stone.slab.line.search</field>
        <field name="model">stone.slab.line</field>
        <field name="arch" type="xml">
            <search string="Tìm Tấm Đá">
                <field name="lot_id" string="Lô Hàng"/>
                <field name="product_id" string="Sản Phẩm"/>
                <field name="sku_code" string="SKU"/>
                <field name="picking_id" string="Phiếu Nhập"/>
                <filter name="filter_normal" string="Đạt"
                        domain="[('quality_status', '=', 'normal')]"/>
                <filter name="filter_pending" string="Chờ Xử Lý"
                        domain="[('quality_status', '=', 'pending')]"/>
                <filter name="filter_defective" string="Lỗi"
                        domain="[('quality_status', '=', 'defective')]"/>
                <group>
                    <filter name="group_lot" string="Lô Hàng"
                            domain="[]" context="{'group_by': 'lot_id'}"/>
                    <filter name="group_product" string="Sản Phẩm"
                            domain="[]" context="{'group_by': 'product_id'}"/>
                    <filter name="group_quality" string="Chất Lượng"
                            domain="[]" context="{'group_by': 'quality_status'}"/>
                    <filter name="group_picking" string="Phiếu Nhập"
                            domain="[]" context="{'group_by': 'picking_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Window Action -->
    <record id="action_stone_slab_line" model="ir.actions.act_window">
        <field name="name">Tấm Đá (Slab Lines)</field>
        <field name="res_model">stone.slab.line</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_stone_slab_line_search"/>

        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Chưa có tấm đá nào được ghi nhận.
            </p>
            <p>
                Slab Lines được tạo từ phiếu nhập kho hoặc trực tiếp từ Lô hàng.
            </p>
        </field>
    </record>

    <!-- Menu Item: Inventory > Sản Phẩm > Tấm Đá -->
    <menuitem id="menu_stone_slab_line"
        name="Tấm Đá (Slab Lines)"
        parent="stock.menu_stock_inventory_control"
        action="action_stone_slab_line"
        sequence="30"
        groups="stock.group_stock_user"/>

</odoo>
