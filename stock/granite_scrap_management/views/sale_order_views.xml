<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sale_order_scrap_inherit_form" model="ir.ui.view">
        <field name="name">sale.order.scrap.inherit.form</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_open_scrap_wizard" string="Xử lý phế phẩm" type="object" class="btn-warning" invisible="state not in ('sale', 'done')"/>
            </xpath>
            
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="%(action_granite_scrap_order)d" type="action" class="oe_stat_button" icon="fa-trash" invisible="scrap_order_count == 0" context="{'search_default_sale_order_id': id}">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_value"><field name="scrap_order_count"/></span>
                        <span class="o_stat_text">Phế phẩm đá</span>
                    </div>
                </button>
            </xpath>
        </field>
    </record>
</odoo>