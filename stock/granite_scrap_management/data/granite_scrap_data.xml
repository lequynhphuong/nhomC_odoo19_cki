<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="seq_granite_scrap_order" model="ir.sequence">
        <field name="name">Granite Scrap Order Sequence</field>
        <field name="code">granite.scrap.order</field>
        <field name="prefix">SCRAP/%(year)s/</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="seq_granite_leftover_stone" model="ir.sequence">
        <field name="name">Granite Leftover Stone Sequence</field>
        <field name="code">granite.leftover.stone</field>
        <field name="prefix">LEFTOVER/%(year)s/</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="stock_location_leftover" model="stock.location">
        <field name="name">Kho Đá Thừa</field>
        <field name="barcode">KHO-DA-THUA</field>
        <field name="usage">internal</field>
        <field name="location_id" ref="stock.stock_location_stock"/>
    </record>

    <record id="stock_location_scrap_granite" model="stock.location">
        <field name="name">Kho Phế Phẩm Đá</field>
        <field name="barcode">KHO-PHE-PHAM</field>
        <field name="usage">inventory</field>
        <field name="location_id" ref="stock.stock_location_stock"/>
    </record>
</odoo>